<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.danielrousseau.odyssey-watcher</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/danielrousseau/odyssey-watcher/watch.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/danielrousseau/odyssey-watcher</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/danielrousseau/odyssey-watcher/watcher.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/danielrousseau/odyssey-watcher/watcher.err.log</string>
</dict>
</plist>
